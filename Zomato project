    },
    {
      "cell_type": "markdown",
      "source": [
        "### Hypothetical Statement - 1"
      ],
      "metadata": {
        "id": "8yEUt7NnHlrM"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "#### 1. State Your research hypothesis as a null hypothesis and alternate hypothesis."
      ],
      "metadata": {
        "id": "tEA2Xm5dHt1r"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "Null Hypothesis (H₀):\n",
        "There is no significant difference in the ratings between high-cost and low-cost restaurants.\n",
        "\n",
        "Alternate Hypothesis (H₁):\n",
        "High-cost restaurants have significantly higher ratings compared to low-cost restaurants."
      ],
      "metadata": {
        "id": "HI9ZP0laH0D-"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "#### 2. Perform an appropriate statistical test."
      ],
      "metadata": {
        "id": "I79__PHVH19G"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Perform Statistical Test to obtain P-Value\n",
        "\n",
        "from scipy.stats import ttest_ind\n",
        "\n",
        "# Convert Cost and Rating columns\n",
        "combined_df['Cost'] = combined_df['Cost'].astype(str).str.replace(',', '')\n",
        "combined_df['Cost'] = pd.to_numeric(combined_df['Cost'], errors='coerce')\n",
        "\n",
        "combined_df['Rating'] = pd.to_numeric(combined_df['Rating'], errors='coerce')\n",
        "\n",
        "# Remove missing values\n",
        "test_df = combined_df[['Cost','Rating']].dropna()\n",
        "\n",
        "# Split restaurants into low and high cost groups using median\n",
        "median_cost = test_df['Cost'].median()\n",
        "\n",
        "low_cost_rating = test_df[test_df['Cost'] <= median_cost]['Rating']\n",
        "high_cost_rating = test_df[test_df['Cost'] > median_cost]['Rating']\n",
        "\n",
        "# Perform Independent T-test\n",
        "t_stat, p_value = ttest_ind(high_cost_rating,\n",
        "                            low_cost_rating,\n",
        "                            equal_var=False)\n",
        "\n",
        "print(\"T-statistic:\", t_stat)\n",
        "print(\"P-value:\", p_value)\n",
        "\n",
        "# Conclusion\n",
        "alpha = 0.05\n",
        "\n",
        "if p_value < alpha:\n",
        "    print(\"Reject Null Hypothesis (H0)\")\n",
        "    print(\"There is a significant difference between ratings of high-cost and low-cost restaurants.\")\n",
        "else:\n",
        "    print(\"Fail to Reject Null Hypothesis (H0)\")\n",
        "    print(\"There is no significant difference between ratings of high-cost and low-cost restaurants.\")"
      ],
